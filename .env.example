# Copy this file to ".env" and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the frontend.

# Supabase → Project Settings → API
# These two are PUBLIC and safe to ship in the frontend.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-public-key...

# Password for the /admin page.
# NOTE: client-side only — it is visible in the built JS, so it deters casual
# access but is not strong security. Real protection comes from Supabase RLS.
VITE_ADMIN_PASSWORD=choose-a-password

# DO NOT put the database password or the service_role key in this file.
